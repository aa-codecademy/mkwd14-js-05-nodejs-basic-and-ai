# Copy this file to `.env` and replace the placeholder values with your own
# MongoDB Atlas credentials.

# Atlas database user credentials
MONGO_USERNAME="your-atlas-username"
MONGO_PASSWORD="your-atlas-password"

# Example values for teaching purposes:
# MONGO_USERNAME="sedc_g2"
# MONGO_PASSWORD="fqVm6gIcpC5XHGW6"

# The cluster host only, without `mongodb+srv://`
# Example: cluster0.xxxxx.mongodb.net
MONGO_CLUSTER="your-cluster.mongodb.net"

# Example:
# MONGO_CLUSTER="cluster0.3y9yiup.mongodb.net"

# The database name Mongoose should connect to
DB_NAME="football"

# Example:
# DB_NAME="football"

# Express server settings
PORT=3000
HOSTNAME="localhost"
